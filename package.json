{
	"name": "@kasumimercury/web-crowd-detection-utils",
	"version": "0.0.0",
	"description": "Reusable building blocks for browser-based crowd / person detection.",
	"type": "module",
	"sideEffects": false,
	"license": "ISC",
	"author": "",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/KasumiMercury/web-crowd-detection-utils.git"
	},
	"homepage": "https://github.com/KasumiMercury/web-crowd-detection-utils#readme",
	"bugs": {
		"url": "https://github.com/KasumiMercury/web-crowd-detection-utils/issues"
	},
	"publishConfig": {
		"registry": "https://npm.pkg.github.com",
		"access": "public"
	},
	"packageManager": "pnpm@10.33.2",
	"engines": {
		"node": ">=20"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./bytetrack": {
			"types": "./dist/bytetrack/index.d.ts",
			"import": "./dist/bytetrack/index.js"
		},
		"./onnx": {
			"types": "./dist/onnx/index.d.ts",
			"import": "./dist/onnx/index.js"
		},
		"./source": {
			"types": "./dist/source/index.d.ts",
			"import": "./dist/source/index.js"
		},
		"./yolo": {
			"types": "./dist/yolo/index.d.ts",
			"import": "./dist/yolo/index.js"
		}
	},
	"dependencies": {
		"onnxruntime-web": "^1.24.3"
	},
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"fix": "biome check --fix .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.13",
		"@vitest/coverage-v8": "^4.1.5",
		"happy-dom": "^20.9.0",
		"tsdown": "^0.21.10",
		"typescript": "~6.0.3",
		"vitest": "^4.1.5"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	}
}
